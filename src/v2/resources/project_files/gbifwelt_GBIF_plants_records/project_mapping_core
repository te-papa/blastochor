# Mapfile for GBIF plants records - core file

# Record-level conditions
reject_if do
    fetch("hasRepresentation").absent?
end

# Hardcoded attributes

# Variable attributes
attribute :record_id, path: "id"

attribute :previousIdentifier, path: "previousIdentifier"

attribute :informationWithheld do
    if memo_check(compose("tepapa:collections/fieldcollection/", fetch("evidenceFor.atEvent.id")), "flag_restrictedLocality").present?
	set_value("something something standard statement")
	fallback(fetch("informationWithheld"))
end

attribute :atEvent, path: "evidenceFor.atEvent"

attribute :atLocation do
    get(:atEvent).fetch("atLocation")
end

attribute :recordedBy do
    get(:atEvent).fetch("recordedBy")
end

attribute :collectionEvent do
    get(:atEvent).fetch("id").lookup("fieldcollection")
end

attribute :currentIdentification do
    fetch("identification").first
end

attribute :currentTypeStatus do
    get(:currentIdentification).fetch("typeStatus")
end

attribute :currentTaxon do
    get(:currentIdentification).fetch("id").lookup("taxon")
end

# Record-level enrichments
enrichment :coordinateWorkaround do
    local(:emuRecord, get(:collectionEvent).fetch("id").use_mapping(:emu_events))
	replace(get(:atLocation).fetch("mappingCentroid.lat"), get_local(:emuRecord).fetch("centroidLatOrWhatever"))
	replace(get(:atLocation).fetch("mappingCentroid.lon"), get_local(:emuRecord).fetch("centroidLonOrWhatever"))
	AND SO ON AND SO ON
end

# Output fields

field :occurrenceID do
    fetch("pid")
end

field :type do
    fetch("additionalType").first
end

field :created do
    fetch("_meta.created")
end

field :modified do
    fetch("_meta.modified")
end

field :language, default: "en"

field :license, default "Creative Commons Attribution 4.0 International license (CC BY 4.0)"

field :rightsHolder do
    fetch("rightsHolder")
end

field :accessRights do
    fetch("accessRights")
end

field :references do
    compose("https://collections.tepapa.govt.nz/object/", get(:record_id))
end

field :institutionID, default: "https://scientific-collections.gbif.org/institution/2749cf1e-60d9-4b03-9c71-3763632b8f78"

field :collectionID, default: "https://scientific-collections.gbif.org/collection/6b5044bb-5fff-49ef-89c1-f52ae9e81550"

field :datasetID, default: "tepapa:collection/dataset/plants"

field :institutionCode, default: "NMNZ"

field :collectionCode, default: "WELT"

field :datasetName, default: "WELT Herbarium at Museum of New Zealand Te Papa Tongarewa"

field :ownerInstitutionCode, default: "NMNZ"

field :basisOfRecord do
    fetch("basisOfRecord")
end

field :informationWithheld

field :dataGeneralizations do
    fetch("dataGeneralizations")
end

field :catalogNumber do
    fetch("identifier")
end

field :recordNumber do
    get(:previousIdentifier)
	for_each(if get("notes").lower.is_in("collector's number", "collector number", "collector(s) number")? fetch("identifier"))
end

field :recordedBy do
    get(:recordedBy).fetch("title")
end

field :recordedByID do
    get(:recordedBy)
	for_each(fetch("id")
	    lookup("agent")
		fetch("related").sort_by("title")
		for_each(if fetch("title").lower.is_in("orcid", "wikidata")?).first
		fetch("contentUrl"))
		
field :sex do
    fetch("sex").split(", ")
end

field :lifeStage do
    fetch("lifeStage").split(", ")
end

field :occurrenceStatus, default: "present"

field :preparations do
    fetch("specimenType")
end

field :otherCatalogNumbers do
